<?xml version="1.0" encoding="utf-8"?>
<paths>
    <!-- Mapea el acceso seguro a los archivos (PDF/CSV/HTML) autogenerados -->
    <external-files-path name="emma_documents" path="Documents/" />
    <!-- Por si acaso en algunos SOs lo guarda genérico en files -->
    <external-files-path name="emma_files" path="." />
    <!-- Cache interna: imágenes, música, videos y audio generados por Pollinations -->
    <cache-path name="emma_cache" path="." />
    <!-- Acceso al directorio público Downloads/EMMA/ donde se guardan archivos generados -->
    <external-path name="emma_downloads" path="Download/EMMA/" />
    <!-- Adjuntos de tareas copiados a almacenamiento interno (context.filesDir) -->
    <files-path name="task_attachments" path="task_attachments/" />
    <!-- Fallback: cualquier archivo en filesDir (para attachments de plugins) -->
    <files-path name="internal_files" path="." />
</paths>
